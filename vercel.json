{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app.oohmyad.com" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.oohmyad.com" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
